# =============================================================================
# maimai-mcp 环境变量示例
# 复制为 maimai_mcp/.env 后填写；勿将含密钥的 .env 提交到 Git
# 也可写在 MCP 客户端配置的 env 字段（见仓库根目录 mcp.example.json / README）
# =============================================================================

# --- 路径与资源（必填 / 常用）---
# static 资源目录的绝对路径（必填）。解压资源包后指向该目录。
# 环境变量名：STATIC_PATH（兼容旧名 MAIMAIDX_PATH）
STATIC_PATH=
# 别名请求是否走国内代理域名（true → yuzuchan.cn，false → yuzuchan.moe）
MAIMAIDX_ALIAS_PROXY=false
# 启动时是否把主题贴图等预载入内存（true 更吃内存、出图更快）
SAVE_IN_MEMORY=true
# 资源是否允许在线补全（封面等缺失时拉取）
ASSETS_ONLINE=true
# 展示用机器人名称（运势文案、落雪授权提示等）
BOT_NAME=maimai
# 出图默认输出目录（相对或绝对路径；默认可为仓库下 output/）
OUTPUT_DIR=

# --- 水鱼查分器 Diving-Fish（强烈建议）---
# 开发者 Token：未配置时多数查分可能仅能使用 b50
# 申请：https://www.diving-fish.com/maimaidx/prober/
DIVINGFISH_TOKEN=
# 是否经代理访问水鱼 API
DIVINGFISH_PROBER_PROXY=false
# 官服成绩上传（maimai records update）运行目录；默认 ~/.cache/maimai-record-imports
# 成绩 Import-Token 存在 user.db（maimai user bind-import），不是开发者 Token
# MAIMAI_UPDATE_RECORDS_OUTPUT_DIR=


# --- 落雪查分器 Lxns（可选；不配也能用水鱼主流程）---
# 开发者 Token：落雪曲库/别名拉取、落雪数据源依赖此项
LXNS_DEV_TOKEN=
# OAuth 绑定落雪账号时使用（bind_lxns / maimai_user_bind_lxns）
LX_CLIENT_ID=
LX_CLIENT_SECRET=
# OAuth 回调，桌面/本机常用：urn:ietf:wg:oauth:2.0:oob
REDIRECT_URI=

# --- 身份缓存（NapCat HTTP 拉取好友/群成员）---
# 需先启动 NapCat 并开启 HTTP：https://github.com/NapNeko/NapCatQQ
# 缓存目录（内写 identity_cache.json；默认 ./qq-identity-cache）
QQ_IDENTITY_CACHE_DIR=
# NapCat HTTP 根地址，例如 http://127.0.0.1:3000 或 http://napcat:3000
NAPCAT_BASE_URL=
# 可选：NapCat HTTP 鉴权 Token
NAPCAT_ACCESS_TOKEN=
# 兼容别名（与上面二选一即可）
# ONEBOT_BASE_URL=
# ONEBOT_ACCESS_TOKEN=
# 拉取每个群成员列表之间的间隔（毫秒）
QQ_IDENTITY_GROUP_DELAY_MS=250

# --- 群榜用本地成绩缓存（个人查 b50/minfo 时旁路写入；群榜只读不主动全群拉分）---
# 默认 ./player-cache
PLAYER_CACHE_DIR=

# 群榜限速（查榜时按需拉分）
# 默认并发 3、成员启动间隔 250ms；成绩缓存 TTL 默认 86400 秒
# GROUP_RANK_MAX_CONCURRENCY=3
# GROUP_RANK_QUERY_DELAY_MS=250
# PLAYER_CACHE_TTL_SECONDS=86400
